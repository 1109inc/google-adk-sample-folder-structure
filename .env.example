APP_NAME=My FastAPI App
APP_VERSION=1.0.0
API_V1_PREFIX=/api/v1

BACKEND_CORS_ORIGINS=["http://localhost:3000"]

DATABASE_URL=sqlite:///./app.db
SESSION_DB_URL=sqlite:///./sessions.db

SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

GOOGLE_API_KEY=replace-with-google-api-key
OPENAI_API_KEY=replace-with-openai-api-key
GPT5_NANO_API_KEY=replace-with-gpt5-nano-api-key
GEMINI_2_5_FLASH_LITE_API_KEY=replace-with-gemini-api-key
ANTHROPIC_API_KEY=replace-with-anthropic-api-key
GROK_API_KEY=replace-with-grok-api-key
